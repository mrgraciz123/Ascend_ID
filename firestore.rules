rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is a recruiter
    function isRecruiter() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'recruiter';
    }

    // Helper function to check if the user is a government official
    function isGovernment() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'government';
    }

    // Helper function to check if the user is a credential issuer
    function isIssuer() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'issuer';
    }

    // Users Collection: Users can read/write their own document
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Students Collection: Users can read/write their own profile, Recruiters and Gov can read
    match /students/{studentId} {
      allow get: if isAuthenticated() && (request.auth.uid == studentId || isRecruiter() || isGovernment());
      allow list: if isAuthenticated() && (isRecruiter() || isGovernment());
      allow write: if isAuthenticated() && request.auth.uid == studentId;

      // Trust History Subcollection: readable by student, recruiter or gov; client writes disabled
      match /trust_history/{historyId} {
        allow read: if isAuthenticated() && (request.auth.uid == studentId || isRecruiter() || isGovernment());
        allow write: if false;
      }

      // Fraud Reports Subcollection: readable by student, recruiter or gov; client writes disabled
      match /fraud_reports/{reportId} {
        allow read: if isAuthenticated() && (request.auth.uid == studentId || isRecruiter() || isGovernment());
        allow write: if false;
      }
    }

    // Academic Records Collection: Users own records where studentId == their uid
    match /academic_records/{recordId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid && request.resource.data.studentId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isRecruiter() || isGovernment());
    }

    // Achievements Collection: Users own achievements where studentId == their uid
    match /achievements/{achievementId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid && request.resource.data.studentId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isRecruiter() || isGovernment());
    }

    // Opportunities Cache Collection: Users can read/write their own cache
    match /opportunities_cache/{studentId} {
      allow read, write: if isAuthenticated() && request.auth.uid == studentId;
    }

    // Proof Documents Collection: Students can only view their own documents
    match /proof_documents/{docId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.studentId == request.auth.uid;
    }

    // Issuers Collection: Anyone authenticated can view details, list restricted to recruiters/issuers/gov
    match /issuers/{issuerId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated() && (isRecruiter() || isIssuer() || isGovernment());
      allow write: if isAuthenticated() && request.auth.uid == issuerId && isIssuer();
    }

    // Credentials Collection: Publicly readable for verification by ID, list restricted to prevent scraping
    match /credentials/{credentialId} {
      allow get: if true; // Allow public to check individual verification pages
      allow list: if isAuthenticated() && (isRecruiter() || isIssuer() || isGovernment());
      allow create: if isIssuer() && request.resource.data.issuerId == request.auth.uid;
      allow update: if isIssuer() && resource.data.issuerId == request.auth.uid && request.resource.data.issuerId == request.auth.uid;
      allow delete: if false; // Deletions strictly blocked client-side
    }

    // Global Fraud Reports Collection: readable by recruiters and gov, client writes disabled
    match /fraud_reports/{candidateId} {
      allow read: if isRecruiter() || isGovernment();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
