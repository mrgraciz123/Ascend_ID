rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is a recruiter
    function isRecruiter() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'recruiter';
    }

    // Users Collection: Users can read/write their own document
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Students Collection: Users can read/write their own profile, Recruiters can read
    match /students/{studentId} {
      allow read: if isAuthenticated() && (request.auth.uid == studentId || isRecruiter());
      allow write: if isAuthenticated() && request.auth.uid == studentId;

      // Trust History Subcollection: readable by student or recruiter, client writes disabled (done via server API)
      match /trust_history/{historyId} {
        allow read: if isAuthenticated() && (request.auth.uid == studentId || isRecruiter());
        allow write: if false;
      }

      // Fraud Reports Subcollection: readable by student or recruiter, client writes disabled (done via server API)
      match /fraud_reports/{reportId} {
        allow read: if isAuthenticated() && (request.auth.uid == studentId || isRecruiter());
        allow write: if false;
      }
    }

    // Academic Records Collection: Users own records where studentId == their uid
    match /academic_records/{recordId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid && request.resource.data.studentId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isRecruiter());
    }

    // Achievements Collection: Users own achievements where studentId == their uid
    match /achievements/{achievementId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.studentId == request.auth.uid && request.resource.data.studentId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.studentId == request.auth.uid || isRecruiter());
    }

    // Opportunities Cache Collection: Users can read/write their own cache
    match /opportunities_cache/{studentId} {
      allow read, write: if isAuthenticated() && request.auth.uid == studentId;
    }

    // Proof Documents Collection: Students can only view their own documents
    match /proof_documents/{docId} {
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.studentId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.studentId == request.auth.uid;
    }

    // Helper function to check if the user is an issuer
    function isIssuer() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'issuer';
    }

    // Issuers Collection: Anyone can read, issuers can write their own
    match /issuers/{issuerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == issuerId && isIssuer();
    }

    // Credentials Collection: Publicly readable for verification, issuers can create and update their own credentials
    match /credentials/{credentialId} {
      allow read: if true;
      allow create: if isIssuer() && request.resource.data.issuerId == request.auth.uid;
      allow update: if isIssuer() && resource.data.issuerId == request.auth.uid && request.resource.data.issuerId == request.auth.uid;
      allow delete: if false;
    }

    // Global Fraud Reports Collection: readable by recruiters, client writes disabled (done via server API)
    match /fraud_reports/{candidateId} {
      allow read: if isRecruiter();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
